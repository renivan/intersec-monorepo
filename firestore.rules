rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Permitir leitura da base de inteligência (Essencial para o motor nativo)
    // Liberado para leitura pública para evitar o PERMISSION_DENIED durante o boot
    match /threat_intel/{document=**} {
      allow read: if true;
      allow write: if false; // Apenas via painel administrativo
    }

    // Regras para dados do usuário (Protegido)
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
